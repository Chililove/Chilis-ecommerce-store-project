generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Decimal     @db.Decimal(10, 2) // kroner; Decimal is exact — never use Float for money
  imageUrl    String?
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  email           String
  status          OrderStatus @default(PENDING)
  // @unique enforces idempotency: a duplicate webhook can't create a second order.
  stripeSessionId String?     @unique
  totalPrice Decimal     @db.Decimal(10, 2) // total charged, in kroner (DKK)
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id         String  @id @default(cuid())
  order      Order   @relation(fields: [orderId], references: [id])
  orderId    String
  product    Product @relation(fields: [productId], references: [id])
  productId  String
  quantity   Int
  price      Decimal @db.Decimal(10, 2) // price at purchase time, in kroner (DKK)
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}
